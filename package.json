{
  "name": "shisha-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "dev": "pnpm run build:data && next dev",
    "prebuild": "npx tsx scripts/build/generate-flavor-image-map.ts",
    "build": "pnpm run build:data && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "pnpm run build:data && tsc --noEmit",
    "test": "pnpm run build:data && jest",
    "test:watch": "pnpm run build:data && jest --watch",
    "test:ci": "pnpm run build:data && jest --ci --coverage",
    "preview": "pnpm run build:data && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm run build:data && opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "next": "^16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
}
