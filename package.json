{
  "name": "shisha-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "picks:candidates": "tsx scripts/list-imaged-flavors.ts",
    "dev": "pnpm run build:data && next dev",
    "prebuild": "npx tsx scripts/build/generate-flavor-image-map.ts",
    "build": "pnpm run build:data && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "pnpm run build:data && tsc --noEmit",
    "test": "pnpm run build:data && jest",
    "test:watch": "pnpm run build:data && jest --watch",
    "test:ci": "pnpm run build:data && jest --ci --coverage",
    "preview": "pnpm run build:data && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm run build:data && opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fetch-mock": "^3.0.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
